{
  "version": "1.0",
  "policy": "load_small_relevant_chunks_only",
  "dataset_types": [
    "memory_dataset",
    "skill_dataset",
    "domain_dataset",
    "workflow_dataset",
    "decision_dataset",
    "pattern_dataset"
  ],
  "rules": {
    "max_active_datasets": 3,
    "prefer_compressed_context": true,
    "prefer_semantic_tags": true,
    "avoid_full_repository_load": true
  },
  "recommended_structure": {
    "id": "unique_runtime_id",
    "domain": "macro-domain",
    "tags": ["semantic", "routing", "keywords"],
    "summary": "compressed high signal context",
    "payload": "operational knowledge",
    "quality_score": 0,
    "last_update": "ISO8601"
  }
}

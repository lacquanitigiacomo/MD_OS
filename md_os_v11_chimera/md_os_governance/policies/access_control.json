{
  "version": "1.0",
  "rules": [
    {
      "role": "admin",
      "allow": [
        "*"
      ]
    },
    {
      "role": "user",
      "allow": [
        "read",
        "execute"
      ],
      "deny": [
        "delete",
        "config"
      ]
    },
    {
      "role": "guest",
      "allow": [
        "read"
      ],
      "deny": [
        "execute",
        "write"
      ]
    }
  ]
}